\citation{Jiang2023}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Comparison of classification accuracy (\%) across three datasets and four methods (LZ78, VADER, TextBlob, NPC-gzip). LZ78 achieves 50.1\% on IMDB, 53.2\% on Amazon, and 62.9\% on tweets. VADER achieves 69.8\%, 71.2\%, and 74.5\% respectively. TextBlob achieves 69.1\%, 68.5\%, and 63.9\%. NPC-gzip performs near random (50.0\%, 50.1\%, 49.0\%). Error bars show 95\% confidence intervals from bootstrap resampling (n=1000).}}{10}{figure.3}\protected@file@percent }
\newlabel{fig:accuracy_comparison}{{3}{10}{Comparison of classification accuracy (\%) across three datasets and four methods (LZ78, VADER, TextBlob, NPC-gzip). LZ78 achieves 50.1\% on IMDB, 53.2\% on Amazon, and 62.9\% on tweets. VADER achieves 69.8\%, 71.2\%, and 74.5\% respectively. TextBlob achieves 69.1\%, 68.5\%, and 63.9\%. NPC-gzip performs near random (50.0\%, 50.1\%, 49.0\%). Error bars show 95\% confidence intervals from bootstrap resampling (n=1000)}{figure.3}{}}
