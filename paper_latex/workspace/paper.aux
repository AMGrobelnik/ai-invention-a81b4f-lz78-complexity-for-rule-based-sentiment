\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Statistical Comparison of LZ78 Complexity Between Positive and Negative Sentiment}}{7}{table.1}\protected@file@percent }
\newlabel{tab:statistical_comparison}{{1}{7}{Statistical Comparison of LZ78 Complexity Between Positive and Negative Sentiment}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Distribution of normalized LZ78 complexity (gzip compressed bytes per character) for positive vs. negative sentiment across three datasets. IMDB reviews show no significant difference (p=0.316, Cliff's delta=-0.007). Amazon reviews show small but significant difference (p$<$0.001, Cliff's delta=0.075) with negative reviews having higher complexity. TweetEval tweets show medium significant difference (p$<$0.001, Cliff's delta=0.347) with negative tweets having higher complexity. Boxplots show median (center line), interquartile range (box), and outliers (dots).}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:complexity_distributions}{{2}{8}{Distribution of normalized LZ78 complexity (gzip compressed bytes per character) for positive vs. negative sentiment across three datasets. IMDB reviews show no significant difference (p=0.316, Cliff's delta=-0.007). Amazon reviews show small but significant difference (p$<$0.001, Cliff's delta=0.075) with negative reviews having higher complexity. TweetEval tweets show medium significant difference (p$<$0.001, Cliff's delta=0.347) with negative tweets having higher complexity. Boxplots show median (center line), interquartile range (box), and outliers (dots)}{figure.2}{}}
